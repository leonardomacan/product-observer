# Required: Base URL of the target web application to observe
TARGET_URL=https://example-app.company.com

# Optional: Browser profile directory (persistent cookies, login sessions)
BROWSER_PROFILE_DIR=./browser_profile

# Optional: Output directory for captured requests
OUTPUT_DIR=data/raw_requests

# Optional: Human-like delay range before navigation (milliseconds)
DELAY_MIN_MS=300
DELAY_MAX_MS=1500

# Optional: Stop capturing after this many requests (empty = no limit)
MAX_REQUESTS_PER_SESSION=

# Optional: Only capture requests from target host (true/false)
FILTER_DOMAIN=true

# Optional: Gzip response files (true/false)
COMPRESS_RESPONSES=false

# Optional: Warn when response exceeds this size (bytes)
LARGE_RESPONSE_THRESHOLD_BYTES=1000000
